@{
    Layout = null;
}

<head>
    <title>Population Monitor</title>

    <script src="//ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js"></script>
    <link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link href="https://cdn.datatables.net/1.11.5/css/dataTables.bootstrap4.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/responsive/2.1.1/css/responsive.bootstrap.min.css" rel="stylesheet" />

    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap4.min.js "></script>

    <script type="text/javascript">

        $(document).ready(function ()
        {
            $("#tblPopulation").DataTable({
                "processing": true,
                "serverSide": true,
                "filter": true,
                "orderMulti": false,
                "ajax": {
                    "url": "/PopulationMonitor/LoadPopulationData",
                    "type": "POST",
                    "datatype": "json"
                },
                "columnDefs":
                [{
                    "targets": [0],
                    "visible": true,
                    "searchable": true
                }],
                "columns": [
                    { "data": "PopulationId", "name": "PopulationId", "autoWidth": true },
                    { "data": "Country", "name": "Country", "autoWidth": true },
                    { "data": "Year", "name": "Year", "autoWidth": true },
                    { "data": "TotalMale", "name": "TotalMale", "autoWidth": true },
                    { "data": "TotalFemale", "name": "TotalFemale", "autoWidth": true },
                    { "data": "PopulationSummary", "name": "PopulationSummary", "autoWidth": true },
                    {
                        "render": function (data, type, row) {
                            return "<a href='javascript:void(0)' onclick = Edit('" + row.PopulationId + "');>Edit</a>";
                        }
                    },
                    {
                        "render": function (data, type, row) {
                            return "<a href='javascript:void(0)' onclick=Delete('" + row.PopulationId + "'); >Delete</a>";
                        }
                    },
                ]
            });
        });

        function Edit(id) {
            if (id) {
                var url = '@Url.Action("Edit", "PopulationMonitor")' + '/' + id;
                window.location.href = url;
            } else {
                return false;
            }

        }


    function Delete(id)
    {
        if (confirm("Are you sure you want to delete the data ?"))
        {
            DeletePopulationData(id);
        }
    }

    function DeletePopulationData(populationId)
    {
        var url = '@Url.Action("DeletePopulationData", "PopulationMonitor")';

        $.ajax({
            type: "POST",
            url: url,
            data: {
                id: populationId
            },
            success: function (data, textStatus, jqXHR) {
                $('#tblPopulation').DataTable().draw();
            }, error: function (data, textStatus, jqXHR) {
                alert("An error occured when performing delete. Please try again");
            }
        });
    }

    </script>
</head>

<body>
    <div class="container">
        <h1> Population Monitor </h1>
        <div style="width:100%;">
            <table id="tblPopulation" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <td colspan="8" style="border-top: 0px; border-bottom: 0px">
                            <a href="@Url.Action("Create","PopulationMonitor")">Add Row</a>
                        </td>
                    </tr>
                    <tr>
                        <th>ID</th>
                        <th>Country</th>
                        <th>Year</th>
                        <th>Total Male</th>
                        <th>Total Female</th>
                        <th>Summary</th>
                        <th></th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</body>






